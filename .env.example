# Copy to .env.local for development. Set in Vercel Project → Environment Variables for production.

# Production site URL is defined in lib/site-contact.ts (metadataBase, sitemap, robots, JSON-LD).

# Google Search Console — HTML tag verification token only (not the full meta tag).
# GSC → Settings → Ownership verification → HTML tag → paste the content value.
# https://search.google.com/search-console
GOOGLE_SITE_VERIFICATION=
